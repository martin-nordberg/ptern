[
  { "id": "lex_error",             "input": "@",              "expect": {"error": "lexError"} },
  { "id": "parse_error",           "input": "* 3",            "expect": {"error": "parseError"} },
  { "id": "line_width_too_small",  "input": "'x'",            "options": {"lineWidth": 39}, "expect": {"error": "invalidLineWidth"} },
  { "id": "line_width_40_ok",      "input": "'x'",            "options": {"lineWidth": 40}, "expect": "'x'" },

  { "id": "double_to_single_quote",       "input": "\"hello\"",                 "expect": "'hello'" },
  { "id": "double_preserved_with_apostrophe", "input": "\"it's\"",              "expect": "\"it's\"" },
  { "id": "char_class_preserved",         "input": "%Alpha",                    "expect": "%Alpha" },
  { "id": "interpolation_normalised",     "input": "d = 'x' ;\n{ d }",          "expect": "d  = 'x' ;\n\n{d}" },
  { "id": "position_assertion_preserved", "input": "@word-start %Alpha * 1..? @word-end", "expect": "@word-start %Alpha * 1..? @word-end" },

  { "id": "sequence_spaced",         "input": "'a' 'b' 'c'",      "expect": "'a' 'b' 'c'" },
  { "id": "alternation_spaces",      "input": "'a'|'b'|'c'",      "expect": "'a' | 'b' | 'c'" },
  { "id": "exact_rep_spaces",        "input": "%Digit*4",          "expect": "%Digit * 4" },
  { "id": "range_rep_spaces",        "input": "%Alpha*1..?",       "expect": "%Alpha * 1..?" },
  { "id": "bounded_rep_spaces",      "input": "%Digit*3..10",      "expect": "%Digit * 3..10" },
  { "id": "lazy_rep_spaces",         "input": "%Digit*1..? fewest","expect": "%Digit * 1..? fewest" },
  { "id": "capture_spaces",          "input": "%Digit*4 as year",  "expect": "%Digit * 4 as year" },
  { "id": "exclusion_spaces",        "input": "%Alpha excluding 'q'","expect": "%Alpha excluding 'q'" },
  { "id": "char_range_spaces",       "input": "'a'..'z'",          "expect": "'a'..'z'" },
  { "id": "group_non_compact",       "input": "('a'|'b')",         "expect": "( 'a' | 'b' )" },

  { "id": "annotation_true",    "input": "!multiline = true\n'x'",   "expect": "!multiline = true\n\n'x'" },
  { "id": "annotation_false",   "input": "!multiline = false\n'x'",  "expect": "!multiline = false\n\n'x'" },
  { "id": "annotations_sorted_aligned", "input": "!multiline = true\n!case-insensitive = true\n'x'",
    "expect": "!case-insensitive = true\n!multiline        = true\n\n'x'" },
  { "id": "two_annotations_aligned", "input": "!substitutable = true\n!multiline = true\n'x'",
    "expect": "!multiline     = true\n!substitutable = true\n\n'x'" },
  { "id": "two_annotations_not_aligned",
    "input": "!substitutable = true\n!multiline = true\n'x'",
    "options": {"aligned": false},
    "expect": "!multiline = true\n!substitutable = true\n\n'x'" },

  { "id": "single_def_aligned", "input": "word = %Alpha * 1..? ;\n{word}",
    "expect": "word  = %Alpha * 1..? ;\n\n{word}" },
  { "id": "two_defs_aligned", "input": "word = %Alpha * 1..? ;\ndigit = %Digit * 1..? ;\n{word} {digit}",
    "expect": "word   = %Alpha * 1..? ;\ndigit  = %Digit * 1..? ;\n\n{word} {digit}" },
  { "id": "two_defs_not_aligned",
    "input": "word = %Alpha * 1..? ;\ndigit = %Digit * 1..? ;\n{word} {digit}",
    "options": {"aligned": false},
    "expect": "word = %Alpha * 1..? ;\ndigit = %Digit * 1..? ;\n\n{word} {digit}" },

  { "id": "def_break_D1",
    "input": "word = %Digit * 4 %Alpha * 4 %Digit * 4 ;\n{word}",
    "options": {"lineWidth": 40, "aligned": false},
    "expect": "word =\n    %Digit * 4 %Alpha * 4 %Digit * 4 ;\n\n{word}" },

  { "id": "def_break_D2",
    "input": "word = 'aaaaaa' 'bbbbbb' 'cccccc' 'dddddd' 'eeeeee' ;\n{word}",
    "options": {"lineWidth": 40, "aligned": false},
    "expect": "word = 'aaaaaa' 'bbbbbb' 'cccccc'\n       'dddddd' 'eeeeee' ;\n\n{word}" },

  { "id": "body_break_B1",
    "input": "'aaaaaa' 'bbbbbb' 'cccccc' 'dddddd' 'eeeeee'",
    "options": {"lineWidth": 40, "aligned": false},
    "expect": "'aaaaaa' 'bbbbbb' 'cccccc' 'dddddd'\n'eeeeee'" },

  { "id": "body_break_B1_repeated",
    "input": "'aaaaaaaaaa' 'bbbbbbbbbb' 'cccccccccc' 'dddddddddd' 'eeeeeeeeee'",
    "options": {"lineWidth": 40, "aligned": false},
    "expect": "'aaaaaaaaaa' 'bbbbbbbbbb' 'cccccccccc'\n'dddddddddd' 'eeeeeeeeee'" },

  { "id": "body_break_B2",
    "input": "'alpha-bravo' | 'charlie-delta' | 'echo-foxtrot'",
    "options": {"lineWidth": 40, "aligned": false},
    "expect": "'alpha-bravo' | 'charlie-delta'\n| 'echo-foxtrot'" },

  { "id": "body_break_B3_no_break",
    "input": "'xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx'",
    "options": {"lineWidth": 40, "aligned": false},
    "expect": "'xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx'" },

  { "id": "compact_removes_alt_spaces",   "input": "'a' | 'b' | 'c'",   "options": {"compact": true}, "expect": "'a'|'b'|'c'" },
  { "id": "compact_removes_rep_spaces",   "input": "%Alpha * 1..?",      "options": {"compact": true}, "expect": "%Alpha*1..?" },
  { "id": "compact_removes_group_spaces", "input": "( 'a' | 'b' )",      "options": {"compact": true}, "expect": "('a'|'b')" },
  { "id": "compact_suppresses_blanks",
    "input": "!multiline = true\nword = %Alpha * 1..? ;\n{word}",
    "options": {"compact": true},
    "expect": "!multiline = true\nword  = %Alpha*1..? ;\n{word}" },
  { "id": "compact_preserves_seq_spaces", "input": "'a' 'b' 'c'",        "options": {"compact": true}, "expect": "'a' 'b' 'c'" },

  { "id": "ptern_comment_blank_line",   "input": "# top comment\n\n'x'",    "expect": "# top comment\n\n'x'" },
  { "id": "body_comment",               "input": "# describes the body\n'x'", "expect": "# describes the body\n'x'" },
  { "id": "annotation_comment",         "input": "# flag\n!multiline = true\n'x'", "expect": "# flag\n!multiline = true\n\n'x'" },
  { "id": "def_comment",                "input": "# about word\nword = %Alpha * 1..? ;\n{word}",
    "expect": "# about word\nword  = %Alpha * 1..? ;\n\n{word}" },
  { "id": "blank_before_commented_def", "input": "a = 'x' ;\n# about b\nb = 'y' ;\n{a} {b}",
    "expect": "a  = 'x' ;\n\n# about b\nb  = 'y' ;\n\n{a} {b}" },
  { "id": "comment_content_verbatim",   "input": "#  two spaces  \n'x'", "expect": "#  two spaces  \n'x'" },
  { "id": "compact_no_blank_before_commented_def",
    "input": "a = 'x' ;\n# about b\nb = 'y' ;\n{a} {b}",
    "options": {"compact": true},
    "expect": "a  = 'x' ;\n# about b\nb  = 'y' ;\n{a} {b}" },

  { "id": "reorder_deps_before_dependents",
    "input": "b = {a} ;\na = 'x' ;\n{b}",
    "options": {"reordered": true, "aligned": false},
    "expect": "a = 'x' ;\nb = {a} ;\n\n{b}" },
  { "id": "reorder_alphabetical_same_layer",
    "input": "c = 'z' ;\na = 'x' ;\n{a} {c}",
    "options": {"reordered": true, "aligned": false},
    "expect": "a = 'x' ;\nc = 'z' ;\n\n{a} {c}" },
  { "id": "reorder_false_preserves_order",
    "input": "b = {a} ;\na = 'x' ;\n{b}",
    "options": {"reordered": false, "aligned": false},
    "expect": "b = {a} ;\na = 'x' ;\n\n{b}" },

  { "id": "idempotent_simple",
    "input": "'hello' 'world'",
    "expect": "'hello' 'world'" },
  { "id": "idempotent_with_anns_defs",
    "input": "!case-insensitive = true\n!multiline = false\n\nword = %Alpha * 1..? ;\n\n{word}",
    "expect": "!case-insensitive = true\n!multiline        = false\n\nword  = %Alpha * 1..? ;\n\n{word}" },

  { "id": "lex_error_unterminated",   "input": "'unterminated",                        "expect": {"error": "lexError"} },
  { "id": "comment_verbatim_trailing","input": "#  two spaces  and trailing  \n'x'",   "expect": "#  two spaces  and trailing  \n'x'" },
  { "id": "idempotent_comments",      "input": "# comment\n\n# about body\n'x'",       "expect": "# comment\n\n# about body\n'x'" }
]
