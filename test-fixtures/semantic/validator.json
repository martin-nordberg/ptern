[
  { "id": "valid_literal",             "pattern": "'hello'",                                    "expect": "ok" },
  { "id": "valid_char_class",          "pattern": "%Digit",                                     "expect": "ok" },
  { "id": "valid_range",               "pattern": "'a'..'z'",                                   "expect": "ok" },
  { "id": "valid_equal_range",         "pattern": "'a'..'a'",                                   "expect": "ok" },
  { "id": "valid_exact_rep",           "pattern": "%Digit * 4",                                 "expect": "ok" },
  { "id": "valid_bounded_rep",         "pattern": "%Digit * 1..10",                             "expect": "ok" },
  { "id": "valid_unbounded_rep",       "pattern": "%Digit * 1..?",                              "expect": "ok" },
  { "id": "valid_exclusion",           "pattern": "%Digit excluding '8'..'9'",                  "expect": "ok" },
  { "id": "valid_capture",             "pattern": "%Digit * 4 as year",                         "expect": "ok" },
  { "id": "valid_annotation",          "pattern": "!case-insensitive = true\n'x'",              "expect": "ok" },
  { "id": "valid_escape_sequences",    "pattern": "'\\n\\t\\r\\'\\\\'",                         "expect": "ok" },
  { "id": "valid_unicode_escape",      "pattern": "'\\u0041'",                                  "expect": "ok" },
  { "id": "valid_excl_charset",        "pattern": "%Digit excluding '0'",                       "expect": "ok" },
  { "id": "valid_excl_group",          "pattern": "%Digit excluding ('1'|'3'|'5'|'7'|'9')",    "expect": "ok" },
  { "id": "valid_excl_range_in_group", "pattern": "%Alpha excluding ('a'..'e' | 'x')",          "expect": "ok" },
  { "id": "valid_excl_charclass",      "pattern": "%Any excluding (%Digit | 'x')",              "expect": "ok" },

  { "id": "empty_literal_single",      "pattern": "''",                                         "expect": {"error": "emptyLiteral"} },
  { "id": "empty_literal_double",      "pattern": "\"\"",                                       "expect": {"error": "emptyLiteral"} },
  { "id": "empty_literal_in_seq",      "pattern": "'a' '' 'b'",                                 "expect": {"error": "emptyLiteral"} },

  { "id": "invalid_escape_z",          "pattern": "'\\z'",                                      "expect": {"error": "invalidEscapeSequence"} },
  { "id": "invalid_escape_q",          "pattern": "'\\q'",                                      "expect": {"error": "invalidEscapeSequence"} },

  { "id": "inverted_range",            "pattern": "'z'..'a'",                                   "expect": {"error": "invertedRange"} },
  { "id": "invalid_range_endpoint",    "pattern": "'ab'..'z'",                                  "expect": {"error": "invalidRangeEndpoint"} },

  { "id": "inverted_rep_bounds",       "pattern": "%Digit * 10..3",                             "expect": {"error": "invertedRepetitionBounds"} },
  { "id": "fewest_on_exact_rep",       "pattern": "%Digit * 4 fewest",                          "expect": {"error": "fewestOnExactRepetition"} },

  { "id": "unknown_annotation",        "pattern": "!bogus = true\n'x'",                         "expect": {"error": "unknownAnnotation"} },
  { "id": "unknown_annotation_case",   "pattern": "!Case-Insensitive = true\n'x'",              "expect": {"error": "unknownAnnotation"} },
  { "id": "duplicate_annotation",      "pattern": "!case-insensitive = true\n!case-insensitive = false\n'x'", "expect": {"error": "duplicateAnnotation"} },

  { "id": "unknown_pos_assertion",     "pattern": "@bogus-pos",                                 "expect": {"error": "unknownPositionAssertion"} },
  { "id": "pos_assertion_in_rep",      "pattern": "@word-start * 3",                            "expect": {"error": "positionAssertionInRepetition"} },

  { "id": "empty_charset",             "pattern": "'x' excluding 'x'",                         "expect": {"error": "emptyCharacterSet"} },
  { "id": "empty_charset_class",       "pattern": "%Digit excluding %Digit",                    "expect": {"error": "emptyCharacterSet"} },
  { "id": "invalid_excl_operand",      "pattern": "%Digit excluding ('1' * 2)",                 "expect": {"error": "invalidExclusionOperand"} },
  { "id": "invalid_excl_sequence",     "pattern": "'a'..'z' excluding ('a' 'b')",               "expect": {"error": "invalidExclusionOperand"} },
  { "id": "invalid_excl_capture",      "pattern": "%Digit excluding ('1' as d)",                "expect": {"error": "invalidExclusionOperand"} },
  { "id": "invalid_excl_literal_body", "pattern": "greeting = 'hello';\n%Alpha excluding {greeting}", "expect": {"error": "invalidExclusionOperand"} },

  { "id": "subst_ignore_without_subst","pattern": "!substitutions-ignore-matching = true\n'x'", "expect": {"error": "substitutionsIgnoreMatchingWithoutSubstitutable"} },
  { "id": "not_substitutable_body",    "pattern": "!substitutable = true\n%Digit",              "expect": {"error": "notSubstitutableBody"} },

  { "id": "multiple_invalid_escapes",  "pattern": "'\\q\\p'",                                   "expect": {"error": "invalidEscapeSequence"} },

  { "id": "equal_bounds_valid",        "pattern": "%Digit * 3..3",                              "expect": "ok" },

  { "id": "range_excl_same_range",     "pattern": "'a'..'z' excluding 'a'..'z'",               "expect": {"error": "emptyCharacterSet"} },
  { "id": "valid_excl_group_single_alt","pattern": "'a'..'z' excluding ('a')",                  "expect": "ok" },
  { "id": "valid_excl_interp_grouped", "pattern": "oddDigit = ('1'|'3'|'5'|'7'|'9');\n%Digit excluding {oddDigit}", "expect": "ok" },
  { "id": "valid_excl_interp_flat",    "pattern": "odds = '1'|'3'|'5';\n%Digit excluding {odds}",                  "expect": "ok" },
  { "id": "invalid_excl_multi_seq",    "pattern": "'a'..'z' excluding ('a' 'b')",               "expect": {"error": "invalidExclusionOperand"} },
  { "id": "invalid_excl_nested_group", "pattern": "%Digit excluding (('1'))",                    "expect": {"error": "invalidExclusionOperand"} },
  { "id": "invalid_excl_interp_multi", "pattern": "d = 'a' 'b'; %Alpha excluding {d}",          "expect": {"error": "invalidExclusionOperand"} },
  { "id": "invalid_excl_group_interp", "pattern": "d = '1'; %Digit excluding ({d})",             "expect": {"error": "invalidExclusionOperand"} },

  { "id": "valid_replacements_ignore", "pattern": "!replacements-ignore-matching = true\n'x'",  "expect": "ok" },
  { "id": "valid_multiline",           "pattern": "!multiline = true\n'x'",                      "expect": "ok" },

  { "id": "valid_capture_in_rep",      "pattern": "(%Digit as d) * 3",                           "expect": "ok" },
  { "id": "valid_capture_outside_rep", "pattern": "%Digit * 3 as d",                             "expect": "ok" },
  { "id": "valid_nested_capture_rep",  "pattern": "(('a' as inner) * 2) * 3",                    "expect": "ok" },

  { "id": "valid_pos_word_start",      "pattern": "@word-start %Alpha * 1..?",                   "expect": "ok" },
  { "id": "valid_pos_word_end",        "pattern": "%Alpha * 1..? @word-end",                     "expect": "ok" },
  { "id": "valid_pos_line_start",      "pattern": "@line-start %Digit * 1..?",                   "expect": "ok" },
  { "id": "valid_pos_line_end",        "pattern": "%Digit * 1..? @line-end",                     "expect": "ok" },
  { "id": "unknown_pos_start_of_line", "pattern": "@start-of-line 'x'",                          "expect": {"error": "unknownPositionAssertion"} },
  { "id": "pos_in_rep_count_1",        "pattern": "@line-end * 1",                               "expect": {"error": "positionAssertionInRepetition"} },

  { "id": "valid_subst_literal",       "pattern": "!substitutable = true\n'hello'",              "expect": "ok" },
  { "id": "valid_subst_capture_class", "pattern": "!substitutable = true\n%Digit * 4 as year",  "expect": "ok" },
  { "id": "invalid_subst_bare_charrange","pattern": "!substitutable = true\n'a'..'z'",           "expect": {"error": "notSubstitutableBody"} },
  { "id": "valid_subst_group_literal", "pattern": "!substitutable = true\n('hello')",            "expect": "ok" },
  { "id": "valid_subst_alt_literals",  "pattern": "!substitutable = true\n'foo' | 'bar'",        "expect": "ok" },
  { "id": "invalid_subst_alt_mixed",   "pattern": "!substitutable = true\n'foo' | %Digit",       "expect": {"error": "notSubstitutableBody"} },
  { "id": "valid_subst_seq_literals",  "pattern": "!substitutable = true\n'hello' ' ' 'world'",  "expect": "ok" },
  { "id": "invalid_subst_seq_mixed",   "pattern": "!substitutable = true\n'hello' %Digit",       "expect": {"error": "notSubstitutableBody"} },
  { "id": "valid_subst_fixed_rep",     "pattern": "!substitutable = true\n'x' * 3",              "expect": "ok" },
  { "id": "valid_subst_bounded_cap",   "pattern": "!substitutable = true\n%Digit * 1..4 as d",   "expect": "ok" },
  { "id": "invalid_subst_bounded_nocap","pattern": "!substitutable = true\n%Digit * 1..4",       "expect": {"error": "boundedRepetitionNeedsCapture"} },
  { "id": "valid_subst_group_bounded_cap","pattern": "!substitutable = true\n(',' %Digit * 1..4 as d) * 0..10", "expect": "ok" },
  { "id": "valid_subst_interp_lit_def","pattern": "!substitutable = true\nword = 'hello';\n{word}", "expect": "ok" },
  { "id": "invalid_subst_interp_class","pattern": "!substitutable = true\ndigits = %Digit * 4;\n{digits}", "expect": {"error": "notSubstitutableBody"} },
  { "id": "valid_subst_interp_outer_cap","pattern": "!substitutable = true\ndigits = %Digit * 4;\n{digits} as year", "expect": "ok" },
  { "id": "valid_subst_ignore_with_subst","pattern": "!substitutable = true\n!substitutions-ignore-matching = true\n'hello'", "expect": "ok" },
  { "id": "valid_subst_ignore_false",  "pattern": "!substitutions-ignore-matching = false\n'hello'", "expect": "ok" },

  { "id": "fewest_on_count_1",         "pattern": "'x' * 1 fewest",                             "expect": {"error": "fewestOnExactRepetition"} },
  { "id": "valid_fewest_unbounded",     "pattern": "%Any * 1..? fewest",                         "expect": "ok" },
  { "id": "valid_fewest_zero_unbounded","pattern": "%Any * 0..? fewest",                         "expect": "ok" },
  { "id": "valid_fewest_bounded",       "pattern": "%Any * 3..10 fewest",                        "expect": "ok" },
  { "id": "valid_fewest_optional",      "pattern": "%Any * 0..1 fewest",                         "expect": "ok" },

  { "id": "invalid_escape_x",          "pattern": "'\\x41'",                                    "expect": {"error": "invalidEscapeSequence"} },
  { "id": "inverted_bounds_100_1",      "pattern": "'a' * 100..1",                              "expect": {"error": "invertedRepetitionBounds"} },
  { "id": "invalid_range_endpoint_right","pattern": "'a'..'yz'",                                "expect": {"error": "invalidRangeEndpoint"} },
  { "id": "inverted_range_9_0",         "pattern": "'9'..'0'",                                  "expect": {"error": "invertedRange"} }
]
